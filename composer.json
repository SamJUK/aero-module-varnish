{
    "name": "samjuk/aero-module-varnish",
    "description": "Experimental Varnish FPC implementation for Aerocommerce",
    "version": "0.0.1",
    "require": {
        "php": "^7.2|^8.0",
        "aerocommerce/core": "^0"
    },
    "autoload": {
        "psr-4": {
            "Samjuk\\Varnish\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Samjuk\\Varnish\\ServiceProvider"
            ]
        }
    },
    "license": "MIT",
    "homepage": "https://github.com/SamJUK/aero-module-varnish",
    "authors": [
        {
            "name": "Sam James",
            "email": "sam@samdjames.uk",
            "homepage": "https://www.samdjames.uk"
        }
    ],
    "keywords": [
        "aero-commerce",
        "aerocommerce",
        "ecommerce",
        "varnish",
        "full-page-cache",
        "fpc",
        "cache",
        "php",
        "experimental",
        "open-source"
    ]
}
